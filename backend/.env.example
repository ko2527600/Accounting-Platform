PORT=4000
NODE_ENV=development

# Database Configuration with Connection Pool Settings
# Connection pool parameters:
# - connection_limit: Maximum number of connections (default: 10, recommended: 50 for production)
# - pool_timeout: Time in seconds to wait for a connection from the pool (default: 10)
# - connect_timeout: Time in seconds to wait for a new connection to be established (default: 5)
# - statement_timeout: Maximum time in milliseconds for a query to run (default: none, recommended: 30000)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/accounting_db?schema=public&connection_limit=50&pool_timeout=10&connect_timeout=5&statement_timeout=30000"

# JWT Secret (REQUIRED in production - MUST be changed from default)
# Generate with: openssl rand -base64 32
JWT_SECRET="super-secret-jwt-key-for-accounting-platform-dev"

# Redis Configuration (for distributed caching and rate limiting)
# Format: redis://[username]:[password]@[host]:[port]/[db_number]
# For Redis Cluster: redis://host1:port1,host2:port2,host3:port3
REDIS_URL="redis://localhost:6379/0"

# OpenTelemetry Configuration (for distributed tracing)
# Set OTEL_ENABLED=false to disable telemetry
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"
OTEL_SERVICE_NAME="accounting-platform-backend"

# Hostname for logging (automatically set in containerized environments)
# HOSTNAME=""

