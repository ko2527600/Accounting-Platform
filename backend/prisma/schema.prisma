// Prisma schema file for Multi-Tenant Accounting Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                   String    @id @default(uuid())
  name                 String
  slug                 String    @unique
  schema               String    @unique
  acceptedTermsVersion String?   @map("accepted_terms_version")
  termsAcceptedAt      DateTime? @map("terms_accepted_at")
  tier                 Int       @default(1)
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  users User[]

  @@index([acceptedTermsVersion, termsAcceptedAt])
  @@map("tenants")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("Viewer")
  tenantId  String?  @map("tenant_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([email, tenantId])
  @@index([isActive])
  @@map("users")
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  VOID
}

model Account {
  id        String      @id @default(uuid())
  code      String      @unique
  name      String
  type      AccountType
  parentId  String?     @map("parent_id")
  currency  String      @default("USD")
  isActive  Boolean     @default(true) @map("is_active")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  parent            Account?           @relation("AccountHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children          Account[]          @relation("AccountHierarchy")
  journalEntryLines JournalEntryLine[]
  ledgers           Ledger[]

  @@index([parentId])
  @@index([type])
  @@index([isActive])
  @@index([type, isActive])
  @@map("accounts")
}

model JournalEntry {
  id          String             @id @default(uuid())
  entryNumber String             @unique @map("entry_number")
  entryDate   DateTime           @default(now()) @map("entry_date")
  description String?
  status      JournalEntryStatus @default(DRAFT)
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  lines   JournalEntryLine[]
  ledgers Ledger[]

  @@index([status])
  @@index([entryDate])
  @@index([status, entryDate])
  @@map("journal_entries")
}

model JournalEntryLine {
  id             String   @id @default(uuid())
  journalEntryId String   @map("journal_entry_id")
  accountId      String   @map("account_id")
  debit          Decimal  @default(0.00) @db.Decimal(15, 2)
  credit         Decimal  @default(0.00) @db.Decimal(15, 2)
  description    String?
  createdAt      DateTime @default(now()) @map("created_at")

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([journalEntryId])
  @@index([accountId])
  @@index([journalEntryId, createdAt])
  @@map("journal_entry_lines")
}

model Ledger {
  id              String   @id @default(uuid())
  accountId       String   @map("account_id")
  transactionDate DateTime @default(now()) @map("transaction_date")
  journalEntryId  String?  @map("journal_entry_id")
  debit           Decimal  @default(0.00) @db.Decimal(15, 2)
  credit          Decimal  @default(0.00) @db.Decimal(15, 2)
  balance         Decimal  @default(0.00) @db.Decimal(15, 2)
  description     String?
  createdAt       DateTime @default(now()) @map("created_at")

  account      Account       @relation(fields: [accountId], references: [id], onDelete: Restrict)
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)

  @@index([accountId, transactionDate(sort: Desc), createdAt(sort: Desc)])
  @@index([journalEntryId])
  @@index([transactionDate])
  @@index([accountId])
  @@map("ledgers")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  APPROVE
  REJECT
  POST
  VOID
}

model AuditLog {
  id         String      @id @default(uuid())
  userId     String      @map("user_id")
  action     AuditAction
  entityType String      @map("entity_type")
  entityId   String      @map("entity_id")
  oldValues  Json?       @map("old_values")
  newValues  Json?       @map("new_values")
  ipAddress  String?     @map("ip_address")
  userAgent  String?     @map("user_agent")
  createdAt  DateTime    @default(now()) @map("created_at")

  @@index([userId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  BOOLEAN
  SELECT
  MULTI_SELECT
}

model CustomField {
  id           String          @id @default(uuid())
  entityType   String          @map("entity_type")
  fieldName    String          @map("field_name")
  fieldLabel   String          @map("field_label")
  fieldType    CustomFieldType @map("field_type")
  isRequired   Boolean         @default(false) @map("is_required")
  options      Json?
  defaultValue String?         @map("default_value")
  displayOrder Int             @default(0) @map("display_order")
  isActive     Boolean         @default(true) @map("is_active")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  values CustomFieldValue[]

  @@unique([entityType, fieldName])
  @@index([entityType, isActive])
  @@map("custom_fields")
}

model CustomFieldValue {
  id            String   @id @default(uuid())
  customFieldId String   @map("custom_field_id")
  entityId      String   @map("entity_id")
  value         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  customField CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)

  @@unique([customFieldId, entityId])
  @@index([entityId])
  @@map("custom_field_values")
}

enum ReportType {
  BALANCE_SHEET
  INCOME_STATEMENT
  CASH_FLOW
  TRIAL_BALANCE
  GENERAL_LEDGER
  ACCOUNT_ACTIVITY
  CUSTOM
}

model ReportDefinition {
  id          String     @id @default(uuid())
  name        String
  reportType  ReportType @map("report_type")
  description String?
  filters     Json?
  columns     Json?
  sortOrder   Json?      @map("sort_order")
  isPublic    Boolean    @default(false) @map("is_public")
  createdBy   String     @map("created_by")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@index([reportType])
  @@index([createdBy])
  @@index([isPublic])
  @@map("report_definitions")
}

model TaxRate {
  id            String    @id @default(uuid())
  name          String
  code          String    @unique
  rate          Decimal   @db.Decimal(5, 4)
  description   String?
  accountId     String?   @map("account_id")
  isActive      Boolean   @default(true) @map("is_active")
  effectiveFrom DateTime  @map("effective_from")
  effectiveTo   DateTime? @map("effective_to")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([code])
  @@index([isActive, effectiveFrom, effectiveTo])
  @@map("tax_rates")
}

enum PeriodStatus {
  OPEN
  CLOSED
  LOCKED
}

model FiscalPeriod {
  id           String       @id @default(uuid())
  name         String
  fiscalYear   Int          @map("fiscal_year")
  periodNumber Int          @map("period_number")
  startDate    DateTime     @map("start_date")
  endDate      DateTime     @map("end_date")
  status       PeriodStatus @default(OPEN)
  closedAt     DateTime?    @map("closed_at")
  closedBy     String?      @map("closed_by")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  budgets Budget[]

  @@unique([fiscalYear, periodNumber])
  @@index([fiscalYear])
  @@index([status])
  @@index([startDate, endDate])
  @@map("fiscal_periods")
}

model Budget {
  id             String   @id @default(uuid())
  accountId      String   @map("account_id")
  fiscalPeriodId String   @map("fiscal_period_id")
  budgetAmount   Decimal  @map("budget_amount") @db.Decimal(15, 2)
  actualAmount   Decimal  @default(0.00) @map("actual_amount") @db.Decimal(15, 2)
  variance       Decimal  @default(0.00) @db.Decimal(15, 2)
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  fiscalPeriod FiscalPeriod @relation(fields: [fiscalPeriodId], references: [id], onDelete: Cascade)

  @@unique([accountId, fiscalPeriodId])
  @@index([accountId])
  @@index([fiscalPeriodId])
  @@map("budgets")
}

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

model RecurringTransaction {
  id           String              @id @default(uuid())
  name         String
  description  String?
  frequency    RecurrenceFrequency
  startDate    DateTime            @map("start_date")
  endDate      DateTime?           @map("end_date")
  lastRun      DateTime?           @map("last_run")
  nextRun      DateTime            @map("next_run")
  templateData Json                @map("template_data")
  isActive     Boolean             @default(true) @map("is_active")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  @@index([isActive, nextRun])
  @@index([frequency])
  @@map("recurring_transactions")
}

enum DocumentType {
  INVOICE
  RECEIPT
  CONTRACT
  STATEMENT
  OTHER
}

model AttachedDocument {
  id           String       @id @default(uuid())
  entityType   String       @map("entity_type")
  entityId     String       @map("entity_id")
  documentType DocumentType @map("document_type")
  fileName     String       @map("file_name")
  fileSize     Int          @map("file_size")
  mimeType     String       @map("mime_type")
  storageUrl   String       @map("storage_url")
  uploadedBy   String       @map("uploaded_by")
  description  String?
  createdAt    DateTime     @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([uploadedBy])
  @@index([documentType])
  @@map("attached_documents")
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model ApprovalWorkflow {
  id            String         @id @default(uuid())
  entityType    String         @map("entity_type")
  entityId      String         @map("entity_id")
  requiredLevel Int            @map("required_level")
  currentLevel  Int            @default(0) @map("current_level")
  status        ApprovalStatus @default(PENDING)
  requestedBy   String         @map("requested_by")
  requestedAt   DateTime       @default(now()) @map("requested_at")
  completedAt   DateTime?      @map("completed_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  approvals ApprovalStep[]

  @@index([entityType, entityId])
  @@index([status])
  @@index([requestedBy])
  @@map("approval_workflows")
}

model ApprovalStep {
  id         String         @id @default(uuid())
  workflowId String         @map("workflow_id")
  level      Int
  approverId String?        @map("approver_id")
  status     ApprovalStatus @default(PENDING)
  comments   String?
  approvedAt DateTime?      @map("approved_at")
  createdAt  DateTime       @default(now()) @map("created_at")

  workflow ApprovalWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([approverId])
  @@index([status])
  @@map("approval_steps")
}
