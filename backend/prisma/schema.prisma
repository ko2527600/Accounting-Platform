// Prisma schema file for Multi-Tenant Accounting Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                   String    @id @default(uuid())
  name                 String
  slug                 String    @unique
  schema               String    @unique
  acceptedTermsVersion String?   @map("accepted_terms_version")
  termsAcceptedAt      DateTime? @map("terms_accepted_at")
  tier                 Int       @default(1)
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  users       User[]
  invitations Invitation[]

  @@index([acceptedTermsVersion, termsAcceptedAt])
  @@map("tenants")
}

model Invitation {
  id        String   @id @default(uuid())
  email     String
  tenantId  String   @map("tenant_id")
  role      String   @default("Viewer")
  token     String   @unique
  status    String   @default("PENDING")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([token])
  @@index([email])
  @@map("invitations")
}

model User {
  id                     String   @id @default(uuid())
  email                  String   @unique
  password               String
  name                   String
  phone                  String?
  role                   String   @default("Viewer")
  tenantId               String?  @map("tenant_id")
  isActive               Boolean  @default(true) @map("is_active")
  isEmailVerified        Boolean  @default(false) @map("is_email_verified")
  isPhoneVerified        Boolean  @default(false) @map("is_phone_verified")
  emailVerificationToken String?  @map("email_verification_token")
  smsVerificationCode    String?  @map("sms_verification_code")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([email, tenantId])
  @@index([isActive])
  @@map("users")
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  VOID
}

model Account {
  id        String      @id @default(uuid())
  code      String      @unique
  name      String
  type      AccountType
  parentId  String?     @map("parent_id")
  currency  String      @default("USD")
  isActive  Boolean     @default(true) @map("is_active")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  parent            Account?           @relation("AccountHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children          Account[]          @relation("AccountHierarchy")
  journalEntryLines JournalEntryLine[]
  ledgers           Ledger[]

  @@index([parentId])
  @@index([type])
  @@index([isActive])
  @@index([type, isActive])
  @@map("accounts")
}

model JournalEntry {
  id          String             @id @default(uuid())
  entryNumber String             @unique @map("entry_number")
  entryDate   DateTime           @default(now()) @map("entry_date")
  description String?
  status      JournalEntryStatus @default(DRAFT)
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  lines   JournalEntryLine[]
  ledgers Ledger[]

  @@index([status])
  @@index([entryDate])
  @@index([status, entryDate])
  @@map("journal_entries")
}

model JournalEntryLine {
  id             String   @id @default(uuid())
  journalEntryId String   @map("journal_entry_id")
  accountId      String   @map("account_id")
  debit          Decimal  @default(0.00) @db.Decimal(15, 2)
  credit         Decimal  @default(0.00) @db.Decimal(15, 2)
  description    String?
  createdAt      DateTime @default(now()) @map("created_at")

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([journalEntryId])
  @@index([accountId])
  @@index([journalEntryId, createdAt])
  @@map("journal_entry_lines")
}

model Ledger {
  id              String   @id @default(uuid())
  accountId       String   @map("account_id")
  transactionDate DateTime @default(now()) @map("transaction_date")
  journalEntryId  String?  @map("journal_entry_id")
  debit           Decimal  @default(0.00) @db.Decimal(15, 2)
  credit          Decimal  @default(0.00) @db.Decimal(15, 2)
  balance         Decimal  @default(0.00) @db.Decimal(15, 2)
  description     String?
  createdAt       DateTime @default(now()) @map("created_at")

  account      Account       @relation(fields: [accountId], references: [id], onDelete: Restrict)
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)

  @@index([accountId, transactionDate(sort: Desc), createdAt(sort: Desc)])
  @@index([journalEntryId])
  @@index([transactionDate])
  @@index([accountId])
  @@map("ledgers")
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  details   String?
  userId    String?  @map("user_id")
  userEmail String?  @map("user_email")
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt(sort: Desc)])
  @@index([entity])
  @@index([userId])
  @@map("audit_logs")
}

model BankAccount {
  id             String            @id @default(uuid())
  accountName    String            @map("account_name")
  accountNumber  String            @map("account_number")
  bankName       String            @map("bank_name")
  currency       String            @default("USD")
  currentBalance Decimal           @default(0.00) @db.Decimal(15, 2) @map("current_balance")
  isActive       Boolean           @default(true) @map("is_active")
  createdAt      DateTime          @default(now()) @map("created_at")

  transactions   BankTransaction[]

  @@map("bank_accounts")
}

model BankTransaction {
  id            String      @id @default(uuid())
  bankAccountId String      @map("bank_account_id")
  amount        Decimal     @db.Decimal(15, 2)
  payee         String
  description   String?
  postedDate    DateTime    @default(now()) @map("posted_date")
  status        String      @default("UNRECONCILED")
  ledgerId      String?     @map("ledger_id")

  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  @@index([bankAccountId])
  @@index([status])
  @@map("bank_transactions")
}

model Customer {
  id        String    @id @default(uuid())
  name      String
  email     String
  phone     String?
  address   String?
  createdAt DateTime  @default(now()) @map("created_at")

  invoices  Invoice[]

  @@map("customers")
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique @map("invoice_number")
  customerId    String        @map("customer_id")
  issueDate     DateTime      @default(now()) @map("issue_date")
  dueDate       DateTime      @map("due_date")
  currency      String        @default("USD")
  exchangeRate  Decimal       @default(1.0000) @db.Decimal(10, 4) @map("exchange_rate")
  subtotal      Decimal       @db.Decimal(15, 2)
  tax           Decimal       @default(0.00) @db.Decimal(15, 2)
  total         Decimal       @db.Decimal(15, 2)
  status        String        @default("DRAFT")
  journalId     String?       @map("journal_id")
  createdAt     DateTime      @default(now()) @map("created_at")

  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items         InvoiceItem[]

  @@index([customerId])
  @@index([status])
  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String   @map("invoice_id")
  description String
  quantity    Decimal  @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(15, 2) @map("unit_price")
  amount      Decimal  @db.Decimal(15, 2)

  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model Vendor {
  id        String       @id @default(uuid())
  name      String
  email     String
  phone     String?
  address   String?
  createdAt DateTime     @default(now()) @map("created_at")

  bills     VendorBill[]

  @@map("vendors")
}

model VendorBill {
  id         String   @id @default(uuid())
  billNumber String   @unique @map("bill_number")
  vendorId   String   @map("vendor_id")
  billDate   DateTime @default(now()) @map("bill_date")
  dueDate    DateTime @map("due_date")
  amount     Decimal  @db.Decimal(15, 2)
  currency   String   @default("USD")
  status     String   @default("UNPAID")
  journalId  String?  @map("journal_id")
  createdAt  DateTime @default(now()) @map("created_at")

  vendor     Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([status])
  @@map("vendor_bills")
}

model Warehouse {
  id          String           @id @default(uuid())
  name        String
  code        String           @unique
  location    String?
  managerName String?          @map("manager_name")
  isPrimary   Boolean          @default(false) @map("is_primary")
  createdAt   DateTime         @default(now()) @map("created_at")

  stocks        WarehouseStock[]
  fromTransfers StockTransfer[] @relation("FromWarehouse")
  toTransfers   StockTransfer[] @relation("ToWarehouse")
  tills         CashTill[]
  closeouts     DailyCloseoutReport[]

  @@map("warehouses")
}

model InventoryItem {
  id            String           @id @default(uuid())
  sku           String           @unique
  name          String
  category      String           @default("General")
  unitOfMeasure String           @default("pcs") @map("unit_of_measure")
  costPrice     Decimal          @db.Decimal(15, 2) @map("cost_price")
  sellingPrice  Decimal          @db.Decimal(15, 2) @map("selling_price")
  reorderLevel  Int              @default(10) @map("reorder_level")
  createdAt     DateTime         @default(now()) @map("created_at")

  warehouseStocks WarehouseStock[]

  @@map("inventory_items")
}

model WarehouseStock {
  id             String        @id @default(uuid())
  warehouseId    String        @map("warehouse_id")
  itemId         String        @map("item_id")
  quantityOnHand Int           @default(0) @map("quantity_on_hand")

  warehouse      Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  item           InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, itemId])
  @@map("warehouse_stocks")
}

model StockTransfer {
  id              String              @id @default(uuid())
  transferNumber  String              @unique @map("transfer_number")
  fromWarehouseId String              @map("from_warehouse_id")
  toWarehouseId   String              @map("to_warehouse_id")
  transferDate    DateTime            @default(now()) @map("transfer_date")
  notes           String?
  status          String              @default("COMPLETED")
  createdAt       DateTime            @default(now()) @map("created_at")

  fromWarehouse   Warehouse           @relation("FromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouse     Warehouse           @relation("ToWarehouse", fields: [toWarehouseId], references: [id])
  items           StockTransferItem[]

  @@map("stock_transfers")
}

model StockTransferItem {
  id          String        @id @default(uuid())
  transferId  String        @map("transfer_id")
  itemId      String        @map("item_id")
  quantity    Int

  transfer    StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@map("stock_transfer_items")
}

model CashTill {
  id              String               @id @default(uuid())
  warehouseId     String               @map("warehouse_id")
  openedBy        String               @map("opened_by")
  openingCash     Decimal              @db.Decimal(15, 2) @map("opening_cash")
  cashSalesTotal  Decimal              @default(0) @db.Decimal(15, 2) @map("cash_sales_total")
  actualEndingCash Decimal?            @db.Decimal(15, 2) @map("actual_ending_cash")
  status          String               @default("OPEN")
  openedAt        DateTime             @default(now()) @map("opened_at")
  closedAt        DateTime?            @map("closed_at")

  warehouse       Warehouse            @relation(fields: [warehouseId], references: [id])
  sales           CashSale[]
  closeoutReport  DailyCloseoutReport?

  @@map("cash_tills")
}

model CashSale {
  id          String   @id @default(uuid())
  tillId      String   @map("till_id")
  receiptNo   String   @unique @map("receipt_no")
  amount      Decimal  @db.Decimal(15, 2)
  cashGiven   Decimal  @db.Decimal(15, 2) @map("cash_given")
  changeGiven Decimal  @db.Decimal(15, 2) @map("change_given")
  createdAt   DateTime @default(now()) @map("created_at")

  till        CashTill @relation(fields: [tillId], references: [id], onDelete: Cascade)

  @@map("cash_sales")
}

model DailyCloseoutReport {
  id           String    @id @default(uuid())
  tillId       String    @unique @map("till_id")
  warehouseId  String    @map("warehouse_id")
  closedBy     String    @map("closed_by")
  openingCash  Decimal   @db.Decimal(15, 2) @map("opening_cash")
  cashSales    Decimal   @db.Decimal(15, 2) @map("cash_sales")
  expectedCash Decimal   @db.Decimal(15, 2) @map("expected_cash")
  actualCash   Decimal   @db.Decimal(15, 2) @map("actual_cash")
  discrepancy  Decimal   @db.Decimal(15, 2)
  itemsSold    Int       @default(0) @map("items_sold")
  notes        String?
  closedAt     DateTime  @default(now()) @map("closed_at")

  till         CashTill  @relation(fields: [tillId], references: [id])
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id])

  @@map("daily_closeout_reports")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  title     String
  message   String
  type      String   @default("SYSTEM")
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([read])
  @@map("notifications")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  APPROVE
  REJECT
  POST
  VOID
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  BOOLEAN
  SELECT
  MULTI_SELECT
}

model CustomField {
  id           String          @id @default(uuid())
  entityType   String          @map("entity_type")
  fieldName    String          @map("field_name")
  fieldLabel   String          @map("field_label")
  fieldType    CustomFieldType @map("field_type")
  isRequired   Boolean         @default(false) @map("is_required")
  options      Json?
  defaultValue String?         @map("default_value")
  displayOrder Int             @default(0) @map("display_order")
  isActive     Boolean         @default(true) @map("is_active")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  values CustomFieldValue[]

  @@unique([entityType, fieldName])
  @@index([entityType, isActive])
  @@map("custom_fields")
}

model CustomFieldValue {
  id            String   @id @default(uuid())
  customFieldId String   @map("custom_field_id")
  entityId      String   @map("entity_id")
  value         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  customField CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)

  @@unique([customFieldId, entityId])
  @@index([entityId])
  @@map("custom_field_values")
}

enum ReportType {
  BALANCE_SHEET
  INCOME_STATEMENT
  CASH_FLOW
  TRIAL_BALANCE
  GENERAL_LEDGER
  ACCOUNT_ACTIVITY
  CUSTOM
}

model ReportDefinition {
  id          String     @id @default(uuid())
  name        String
  reportType  ReportType @map("report_type")
  description String?
  filters     Json?
  columns     Json?
  sortOrder   Json?      @map("sort_order")
  isPublic    Boolean    @default(false) @map("is_public")
  createdBy   String     @map("created_by")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@index([reportType])
  @@index([createdBy])
  @@index([isPublic])
  @@map("report_definitions")
}

model TaxRate {
  id            String    @id @default(uuid())
  name          String
  code          String    @unique
  rate          Decimal   @db.Decimal(5, 4)
  description   String?
  accountId     String?   @map("account_id")
  isActive      Boolean   @default(true) @map("is_active")
  effectiveFrom DateTime  @map("effective_from")
  effectiveTo   DateTime? @map("effective_to")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([code])
  @@index([isActive, effectiveFrom, effectiveTo])
  @@map("tax_rates")
}

enum PeriodStatus {
  OPEN
  CLOSED
  LOCKED
}

model FiscalPeriod {
  id           String       @id @default(uuid())
  name         String
  fiscalYear   Int          @map("fiscal_year")
  periodNumber Int          @map("period_number")
  startDate    DateTime     @map("start_date")
  endDate      DateTime     @map("end_date")
  status       PeriodStatus @default(OPEN)
  closedAt     DateTime?    @map("closed_at")
  closedBy     String?      @map("closed_by")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  budgets Budget[]

  @@unique([fiscalYear, periodNumber])
  @@index([fiscalYear])
  @@index([status])
  @@index([startDate, endDate])
  @@map("fiscal_periods")
}

model Budget {
  id             String   @id @default(uuid())
  accountId      String   @map("account_id")
  fiscalPeriodId String   @map("fiscal_period_id")
  budgetAmount   Decimal  @map("budget_amount") @db.Decimal(15, 2)
  actualAmount   Decimal  @default(0.00) @map("actual_amount") @db.Decimal(15, 2)
  variance       Decimal  @default(0.00) @db.Decimal(15, 2)
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  fiscalPeriod FiscalPeriod @relation(fields: [fiscalPeriodId], references: [id], onDelete: Cascade)

  @@unique([accountId, fiscalPeriodId])
  @@index([accountId])
  @@index([fiscalPeriodId])
  @@map("budgets")
}

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

model RecurringTransaction {
  id           String              @id @default(uuid())
  name         String
  description  String?
  frequency    RecurrenceFrequency
  startDate    DateTime            @map("start_date")
  endDate      DateTime?           @map("end_date")
  lastRun      DateTime?           @map("last_run")
  nextRun      DateTime            @map("next_run")
  templateData Json                @map("template_data")
  isActive     Boolean             @default(true) @map("is_active")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  @@index([isActive, nextRun])
  @@index([frequency])
  @@map("recurring_transactions")
}

enum DocumentType {
  INVOICE
  RECEIPT
  CONTRACT
  STATEMENT
  OTHER
}

model AttachedDocument {
  id           String       @id @default(uuid())
  entityType   String       @map("entity_type")
  entityId     String       @map("entity_id")
  documentType DocumentType @map("document_type")
  fileName     String       @map("file_name")
  fileSize     Int          @map("file_size")
  mimeType     String       @map("mime_type")
  storageUrl   String       @map("storage_url")
  uploadedBy   String       @map("uploaded_by")
  description  String?
  createdAt    DateTime     @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([uploadedBy])
  @@index([documentType])
  @@map("attached_documents")
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model ApprovalWorkflow {
  id            String         @id @default(uuid())
  entityType    String         @map("entity_type")
  entityId      String         @map("entity_id")
  requiredLevel Int            @map("required_level")
  currentLevel  Int            @default(0) @map("current_level")
  status        ApprovalStatus @default(PENDING)
  requestedBy   String         @map("requested_by")
  requestedAt   DateTime       @default(now()) @map("requested_at")
  completedAt   DateTime?      @map("completed_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  approvals ApprovalStep[]

  @@index([entityType, entityId])
  @@index([status])
  @@index([requestedBy])
  @@map("approval_workflows")
}

model ApprovalStep {
  id         String         @id @default(uuid())
  workflowId String         @map("workflow_id")
  level      Int
  approverId String?        @map("approver_id")
  status     ApprovalStatus @default(PENDING)
  comments   String?
  approvedAt DateTime?      @map("approved_at")
  createdAt  DateTime       @default(now()) @map("created_at")

  workflow ApprovalWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([approverId])
  @@index([status])
  @@map("approval_steps")
}
